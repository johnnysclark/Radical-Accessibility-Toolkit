{
  "name": "enclose-bay-with-door",
  "description": "Turn on walls for a bay and add a single entry door.",
  "version": 1,
  "commands": [
    "wall {bay} on",
    "wall {bay} thickness {wall_thickness}",
    "aperture {bay} add {door_id} door {axis} {gridline} {corner} {door_width} {door_height}"
  ],
  "params": {
    "bay": {
      "description": "Target bay name",
      "default": "A"
    },
    "wall_thickness": {
      "description": "Wall thickness in feet",
      "default": "0.5"
    },
    "door_id": {
      "description": "Unique door ID",
      "default": "d1"
    },
    "axis": {
      "description": "Door wall axis (x or y)",
      "default": "x"
    },
    "gridline": {
      "description": "Gridline index for door placement",
      "default": "0"
    },
    "corner": {
      "description": "Distance from corner to door in feet",
      "default": "10"
    },
    "door_width": {
      "description": "Door width in feet (ADA min: 3)",
      "default": "3"
    },
    "door_height": {
      "description": "Door height in feet",
      "default": "7"
    }
  }
}